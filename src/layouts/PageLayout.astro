---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header />
  <main class="min-h-screen">
    <slot />
  </main>
  <Footer />
</BaseLayout>
