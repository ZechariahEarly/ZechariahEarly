---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Only show h2 and h3
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="hidden lg:block sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto" aria-label="Table of contents">
    <p class="font-heading text-xs text-text-secondary uppercase tracking-wider mb-4">On this page</p>
    <ul class="space-y-2 border-l border-border">
      {filtered.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block text-sm text-text-secondary hover:text-accent-blue transition-colors duration-200 border-l-2 border-transparent hover:border-accent-blue -ml-px',
              heading.depth === 2 ? 'pl-4' : 'pl-8',
            ]}
            data-toc-link
            data-toc-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  const headings = Array.from(tocLinks).map((link) => {
    const slug = link.getAttribute('data-toc-slug');
    return { link, el: slug ? document.getElementById(slug) : null };
  }).filter((h) => h.el);

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          tocLinks.forEach((l) => {
            l.classList.remove('text-accent-blue', 'border-accent-blue');
            l.classList.add('text-text-secondary', 'border-transparent');
          });
          const active = document.querySelector(`[data-toc-slug="${entry.target.id}"]`);
          if (active) {
            active.classList.add('text-accent-blue', 'border-accent-blue');
            active.classList.remove('text-text-secondary', 'border-transparent');
          }
        }
      });
    },
    { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
  );

  headings.forEach(({ el }) => el && observer.observe(el));
</script>
