---

---

<div class="border-t border-border p-6 bg-bg-tertiary/50">
  <p class="font-mono text-xs text-text-secondary mb-4">// terminal preview</p>

  <!-- Terminal window -->
  <div class="rounded-lg overflow-hidden border border-border">
    <!-- Title bar -->
    <div class="bg-bg-secondary px-4 py-2.5 flex items-center gap-2 border-b border-border">
      <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
      <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
      <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
      <span class="ml-2 font-mono text-xs text-text-secondary">swiftbits</span>
    </div>

    <!-- Terminal body -->
    <div class="bg-code-bg p-4 font-mono text-xs leading-relaxed">
      <div class="terminal-line" style="--delay: 0">
        <span class="text-accent-green">$</span>
        <span class="text-text-primary"> swiftbits embed ./docs --collection notes</span>
      </div>
      <div class="terminal-line" style="--delay: 1">
        <span class="text-text-secondary">Scanning ./docs for documents...</span>
      </div>
      <div class="terminal-line" style="--delay: 2">
        <span class="text-text-secondary">Found 12 files (3 .md, 5 .txt, 4 .pdf)</span>
      </div>
      <div class="terminal-line" style="--delay: 3">
        <span class="text-accent-blue">Chunking</span>
        <span class="text-text-secondary"> ████████████████████ 100%</span>
      </div>
      <div class="terminal-line" style="--delay: 4">
        <span class="text-accent-blue">Embedding</span>
        <span class="text-text-secondary"> ████████████████████ 100%</span>
      </div>
      <div class="terminal-line" style="--delay: 5">
        <span class="text-accent-green">✓</span>
        <span class="text-text-primary"> Done. 47 chunks embedded to collection "notes"</span>
      </div>
      <div class="terminal-line" style="--delay: 6">
        <span class="text-text-secondary">MCP server ready at localhost:3100</span>
      </div>
    </div>
  </div>
</div>

<style>
  .terminal-line {
    opacity: 0;
    animation: fadeIn 0.3s ease-out forwards;
    animation-delay: calc(var(--delay) * 0.4s + 0.5s);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
